{
  "name": "coc-tools",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:realtime": "npm run dev --workspace apps/realtime",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:coc": "npm run test --workspace @coc-tools/coc-rules",
    "db:generate": "npm run db:generate --workspace @coc-tools/db",
    "db:migrate": "npm run db:migrate --workspace @coc-tools/db",
    "db:push": "npm run db:push --workspace @coc-tools/db",
    "db:studio": "npm run db:studio --workspace @coc-tools/db"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}