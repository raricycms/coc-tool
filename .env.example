# Database (SQLite for current development; switch the Prisma provider for PostgreSQL)
DATABASE_URL="file:./dev.db"

# Auth — replace with a strong random value before running the app
SESSION_SECRET="change-me-to-a-strong-random-secret-at-least-32-bytes"

# Web app
WEB_ORIGIN="http://localhost:7766"

# Realtime service
REALTIME_PORT=4000
NEXT_PUBLIC_WS_URL="http://localhost:4000"
LOG_LEVEL="info"

# raricy OAuth (optional for local development)
RARICY_OAUTH_CLIENT_ID=""
RARICY_OAUTH_CLIENT_SECRET=""
RARICY_OAUTH_AUTHORIZE_URL="https://raricy.com/oauth/authorize"
RARICY_OAUTH_TOKEN_URL="https://raricy.com/api/oauth/token"
RARICY_OAUTH_USERINFO_URL="https://raricy.com/api/oauth/userinfo"
RARICY_OAUTH_REVOKE_URL="https://raricy.com/api/oauth/revoke"
RARICY_OAUTH_REDIRECT_URI="http://localhost:7766/api/auth/raricy/callback"
